# 使用 pipenv 布局自动激活虚拟环境
layout pipenv

# Python 环境变量
export PYTHONPATH="${PWD}:${PYTHONPATH}"

# 数据集默认存储路径（原始数据下载目录）
export DATA_ROOT="${PWD}/data"

# 数据集配置目录（存放各数据集的 config.json）
export DB_RAW_PATH="${PWD}/data_configs"

# 划分策略配置目录（存放各策略的 json 配置）
export DB_PARTITION_PATH="${PWD}/partition_configs"

# 日志级别
export LOG_LEVEL="INFO"

# 自动创建必要的目录
mkdir -p "${DATA_ROOT}"
mkdir -p "${DB_PARTITION_PATH}"

echo "[direnv] 联邦学习数据集管理框架环境已激活"
