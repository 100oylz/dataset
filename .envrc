# 使用 pipenv 布局自动激活虚拟环境
layout pipenv

# Python 环境变量
export PYTHONPATH="${PWD}:${PYTHONPATH}"

# 数据集默认存储路径（原始数据下载目录）
export DATA_ROOT="${PWD}/data"

# 数据集配置目录（存放各数据集的 config.json）
export DB_RAW_PATH="${PWD}/data_configs"

# 划分策略配置目录（存放各策略的 json 配置）
export DB_PARTITION_PATH="${PWD}/partition_configs"

# 日志级别
export LOG_LEVEL="INFO"

# ============================================
# MySQL 数据库环境变量配置
# ============================================

# MySQL 连接配置
export MYSQL_HOST="${MYSQL_HOST:-localhost}"
export MYSQL_PORT="${MYSQL_PORT:-3306}"
export MYSQL_DATABASE="${MYSQL_DATABASE:-fl_dataset_db}"
export MYSQL_USER="${MYSQL_USER:-fl_user}"
export MYSQL_PASSWORD="${MYSQL_PASSWORD:-flpassword}"
export MYSQL_ROOT_PASSWORD="${MYSQL_ROOT_PASSWORD:-rootpassword}"

# 数据库连接池配置
export MYSQL_POOL_SIZE="${MYSQL_POOL_SIZE:-5}"
export MYSQL_MAX_OVERFLOW="${MYSQL_MAX_OVERFLOW:-10}"
export MYSQL_POOL_TIMEOUT="${MYSQL_POOL_TIMEOUT:-30}"
export MYSQL_POOL_RECYCLE="${MYSQL_POOL_RECYCLE:-3600}"

# 构建完整的数据库 URL
export DATABASE_URL="mysql+pymysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DATABASE}?charset=utf8mb4"

# Adminer 管理界面端口（可选）
export ADMINER_PORT="${ADMINER_PORT:-8080}"

# ============================================
# 自动创建必要的目录
# ============================================
mkdir -p "${DATA_ROOT}"
mkdir -p "${DB_PARTITION_PATH}"
mkdir -p "${DB_RAW_PATH}"
mkdir -p "${PWD}/database/init"

echo "[direnv] 联邦学习数据集管理框架环境已激活"
echo "[direnv] MySQL 配置: ${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DATABASE}"
echo "[direnv] DATABASE_URL: ${DATABASE_URL//${MYSQL_PASSWORD}/****}"
